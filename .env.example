# PocketBase connection settings
POCKETBASE_URL=http://localhost:8090
POCKETBASE_ADMIN_EMAIL=admin@yourdomain.com
POCKETBASE_ADMIN_PASSWORD=your-secure-password-here

# Optional: authenticate against a non-superuser auth collection instead
# POCKETBASE_AUTH_COLLECTION=_superusers

# Optional: use a pre-issued auth token instead of email/password
# POCKETBASE_TOKEN=
