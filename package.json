{
  "name": "pocketbase-mcp",
  "version": "1.0.0",
  "description": "Complete Model Context Protocol (MCP) server for PocketBase — collections, records, auth, files, logs, settings, backups, crons and more.",
  "type": "module",
  "mcpName": "io.github.nestebe/pocketbase-mcp",
  "bin": {
    "pocketbase-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://github.com/nestebe/pocketbase-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nestebe/pocketbase-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/nestebe/pocketbase-mcp/issues"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "modelcontextprotocol",
    "pocketbase",
    "claude",
    "llm",
    "ai",
    "backend"
  ],
  "author": "Nicolas ESTEBE <devestebe@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "pocketbase": "^0.26.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
